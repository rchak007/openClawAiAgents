[Unit]
Description=Todo Tree Web UI
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/github/openClawAiAgents
ExecStart=/usr/bin/python3 -m uvicorn todo_tree_server:app --host 0.0.0.0 --port 8081
Restart=always
RestartSec=5
Environment=TODO_FILE=%h/.openclaw/workspace/todos.json

[Install]
WantedBy=default.target
